# ── Meta WhatsApp Business API ──────────────────────────
META_WHATSAPP_TOKEN=your_meta_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_VERIFY_TOKEN=mexico-limited-verify-2024
META_API_VERSION=v21.0

# ── Google Sheets ───────────────────────────────────────
# Option A: Path to the Service Account credentials JSON file (local dev)
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
# Option B: Paste the ENTIRE JSON content here (for Render/Cloud deploy)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# The ID from the Google Sheets URL: docs.google.com/spreadsheets/d/{THIS_ID}/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=Nuevos_Leads

# ── LLM (OpenAI) ───────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# ── Email Notifications (SendGrid) ─────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_FROM_EMAIL=agente@mexicolimited.com
EXECUTIVE_EMAIL=ejecutivo@mexicolimited.com
EXECUTIVE_PHONE=+525500000000

# ── Datos de Pago ──────────────────────────────────────
PAYMENT_BANK_NAME=BBVA
PAYMENT_ACCOUNT_NAME=Mexico Limited S.A. de C.V.
PAYMENT_CLABE=012345678901234567
PAYMENT_REFERENCE=ML2024
PAYMENT_AMOUNT=$2,499 MXN

# ── Links de Onboarding ───────────────────────────────
CALENDLY_LINK=https://calendly.com/mexicolimited
ONBOARDING_GUIDE_LINK=https://docs.google.com/document/d/xxx
CLASSROOM_LINK=https://classroom.google.com/xxx
TIENDANUBE_LINK=https://www.tiendanube.com/xxx

# ── Application ───────────────────────────────────────
FLASK_ENV=development
PAYMENT_POLL_INTERVAL_MINUTES=5
